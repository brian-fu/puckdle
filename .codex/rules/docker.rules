prefix_rule(pattern=["docker-compose", "up"], decision="allow")
prefix_rule(pattern=["docker-compose", "down"], decision="allow")
prefix_rule(pattern=["docker-compose", "build"], decision="allow")
prefix_rule(pattern=["docker-compose", "logs"], decision="allow")

prefix_rule(pattern=["docker", "system", "prune"], decision="ask", justification="Check if build cache is needed.")
prefix_rule(pattern=["docker", "volume", "rm"], decision="ask", justification="Do not blindly delete the PostgreSQL data volume.")